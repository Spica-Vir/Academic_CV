% Hyperlink and colors setup

\definecolor{linkcolor}{RGB}{0,0,199}
\hypersetup{
    colorlinks=true,
    linkcolor=linkcolor,
    filecolor=linkcolor,
    urlcolor=linkcolor
}
\AtBeginDocument{
    \hypersetup{
        pdfauthor={\@myname},
        pdftitle={Curriculum Vitae for \@myname}
    }
}

% set general styles

\setlength{\parindent}{0mm}
\newcommand{\BeforeSectionTitle}{1mm}
\newcommand{\AfterSectionTitle}{0mm}
\newcommand{\BeforeSubsectionTitle}{0mm}
\newcommand{\AfterSubsectionTitle}{0mm}

\newcommand{\AfterNameSkip}{\vspace{4.5mm}}
\newcommand{\IconSep}{\hspace{0.5em}}
\newcommand{\IconInline}[1]{\raisebox{-0.05em}{#1}}
\newcommand{\EntrySeparator}{\hspace{0.75em}\textbar\hspace{0.75em}}
\newcommand{\BeforeTextSkip}{\vspace{1mm}} % added before text paragraph / list immediately after section titles
\newcommand{\AfterTextSkip}{\vspace{2mm}}
\raggedbottom
% \widowpenalty=0
% \clubpenalty=0
\titleformat{\section}{
    \bfseries \raggedright \large \sffamily
}{}{0em}{}[\vspace{-3mm}\rule{\textwidth}{0.5pt}]
\titlespacing*{\section}{0mm}{\BeforeSectionTitle}{\AfterSectionTitle}

\titleformat{\subsection}{
    \bfseries \raggedright \sffamily
}{}{0em}{}
\titlespacing*{\subsection}{0mm}{\BeforeSubsectionTitle}{\AfterSubsectionTitle}

% set 2x2 table styles

\newcommand{\RightColWidth}{5.5cm}
\newcommand{\TopLeftStyle}[1]{\textbf{#1}}
\newcommand{\TopRightStyle}[1]{#1}
\newcommand{\BottomLeftStyle}[1]{\textit{#1}}
\newcommand{\BottomRightStyle}[1]{#1}
\newcommand{\DescriptionStyle}[1]{#1 \AfterTextSkip}

\newcolumntype{L}[1]{>{\raggedright\let\newline\\\arraybackslash\hspace{0pt}}p{#1}}
\newcolumntype{C}[1]{>{\centering\let\newline\\\arraybackslash\hspace{0pt}}p{#1}}
\newcolumntype{R}[1]{>{\raggedleft\let\newline\\\arraybackslash\hspace{0pt}}p{#1}}

% set list styles

\newcommand{\ListIndent}{2em}
\newcommand{\ListTextIndent}{4em} % for text bullet points (ORAL, POSTER, GUEST, KEYNOTE etc.)
\setlist{itemsep=0pt, parsep=0pt, topsep=0pt, partopsep=0pt, leftmargin=\ListIndent}

% set the header

\newcommand{\makeheader}{
    \begin{center}
        {\Huge \sffamily \textbf{\@myname}}
        \AfterNameSkip

        \@myposition

        \textit{\@myaddress}
        \vspace{3mm}

        \ifdefempty{\@mysite}
            {电话：\IconSep\@mytel \EntrySeparator 邮箱：\IconSep\href{mailto:\@myemail}{\@myemail}}
            {电话：\IconSep\@mytel \EntrySeparator 邮箱：\IconSep\href{mailto:\@myemail}{\@myemail} \EntrySeparator 个人主页：\href{https://\@mysite}{\@mysite}}
    \end{center}
}

% academic contact environment
\newenvironment{acmedia}{
    \begin{center}
    \vspace{-3.5mm}
}{
    \end{center}
    \AfterTextSkip
}
% more icons see fontawesome5 and academicons
