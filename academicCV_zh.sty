\newcommand{\myORCID}[2]{\IconInline{\aiOrcid}\IconSep\href{#1}{#2}}
\newcommand{\myResearchGate}[2]{\IconInline{\aiResearchGate}\IconSep\href{#1}{#2}}
\newcommand{\myAcademia}[2]{\IconInline{\aiAcademia}\IconSep\href{#1}{#2}}
\newcommand{\myGitHub}[2]{\IconInline{\faGithub}\IconSep\href{#1}{#2}}
\newcommand{\myLinkedIn}[2]{\IconInline{\faLinkedin}\IconSep\href{#1}{#2}}
\newcommand{\myTwitter}[2]{\IconInline{\faTwitter}\IconSep\href{#1}{#2}}

% an entry of education / employment experience
% Usage: \experience{<position>}{<date>}{<organization>}{<location>}{<description(optional)>}

\newcommand{\experience}[5]{
    \setlength\tabcolsep{0pt}
    \setlength{\extrarowheight}{0pt}
    \begin{tabular*}{\textwidth}{@{\extracolsep{\fill}} L{\textwidth - \RightColWidth} R{\RightColWidth}}
        \TopLeftStyle{#1}    & \TopRightStyle{#2} \\
        \BottomLeftStyle{#3} & \BottomRightStyle{#4}
    \ifstrempty{#5}
        {
            \end{tabular*}
        }{
            \end{tabular*}
            \DescriptionStyle{#5}
        }
}

% an entry of fellowship / honor / award etc. 
% Usage: \award{<name>}{<date>}{<event>}{<description(optional)>}

\newcommand{\award}[4]{
    \setlength\tabcolsep{0pt}
    \setlength{\extrarowheight}{0pt}
    \begin{tabular*}{\textwidth}{@{\extracolsep{\fill}} L{\textwidth - \RightColWidth} R{\RightColWidth}}
        \TopLeftStyle{#1}    & \TopRightStyle{#2} \\
        \BottomLeftStyle{#3} &
    \ifstrempty{#4}
        {
            \end{tabular*}
        }{
            \end{tabular*}
            \DescriptionStyle{#4}
        }
}

% an entry of research grant
% Usage: \grant{<name>}{<date>}{<source>}{<amount(optional)>}{<description(optional)>}

\newcommand{\grant}[5]{
    \setlength\tabcolsep{0pt}
    \setlength{\extrarowheight}{0pt}
    \ifstrempty{#4}
        {
            \begin{tabular*}{\textwidth}{@{\extracolsep{\fill}} L{\textwidth - \RightColWidth} R{\RightColWidth}}
                \TopLeftStyle{#1}    & \TopRightStyle{#2} \\
                \BottomLeftStyle{#3} & 
        }{
            \begin{tabular*}{\textwidth}{@{\extracolsep{\fill}} L{\textwidth - \RightColWidth} R{\RightColWidth}}
                \TopLeftStyle{#1}    & \TopRightStyle{#2} \\
                \BottomLeftStyle{#3} & \BottomRightStyle{#4}
        }
    
    \ifstrempty{#5}
        {
            \end{tabular*}
        }{
            \end{tabular*}
            \DescriptionStyle{#5}
        }
}

% Publication list environment
% Usage: \begin{paperlist}[ascending=<true/false>]\end{paperlist}

\define@boolkey{papers}{ascending}[true]{}
\newenvironment{paperlist}[1][]{
    \BeforeTextSkip
    \setkeys{papers}{ascending=true, #1}
    \ifKV@papers@ascending
        \begin{enumerate}[label={[\arabic*]}]
    \else
        \renewcommand{\labelenumi}{[\theenumi]}
        \begin{etaremune}[itemsep=0pt, parsep=0pt, topsep=0pt, partopsep=0pt, leftmargin=\ListIndent]
    \fi
}{
    \AfterTextSkip
    \ifKV@papers@ascending
        \end{enumerate}
    \else
        \end{etaremune}
    \fi
}

% Journal paper entry, must be used within paperlist environment
% Usage: \journal{<author>}{<title>}{<journal>}{<year>}{<volume(optional)>}{<issue(optional)>}{<page(optional)>}{<DOI(optional, without https://doi.org/)>}{<other comments(optional)>}

\newcommand{\DOI}[2]{\href{https://doi.org/#1}{#2}}
\newcommand{\journal}[9]{
    \item %
    #1. %
    \ifstrempty{#8}{#2. }{\DOI{#8}{#2}. }%
    \textit{#3}, #4;%
    \ifstrempty{#5}{}{#5}%
    \ifstrempty{#6}{: }{(#6): }%
    \ifstrempty{#7}{. }{#7. }%
    \ifstrempty{#9}{}{#9}%
}

% Preprint entry, must be used within paperlist environment
% Usage: \preprint{<author>}{<title>}{<journal/server>}{<status>}{<year>}{<DOI(optional, without https://doi.org/)>}{<other comments(optional)>}

\newcommand{\preprint}[7]{
    \item %
    #1. %
    \ifstrempty{#6}{#2. }{\DOI{#6}{#2}. }%
    \textit{#3} [#4], #5. %
    \ifstrempty{#7}{}{#7}%
}

% Conference paper entry, must be used within paperlist environment
% Usage: \conference{<author>}{<title>}{<conference>}{<location>}{<date>}{<URL(optional)>}{<other comments(optional)>}

\newcommand{\conference}[7]{
    \item %
    #1. %
    \ifstrempty{#6}{#2. }{\href{#6}{#2}. }%
    Presented at \textit{#3}, #4. (#5). %
    \ifstrempty{#7}{}{#7}%
}

% Book chapter entry, must be used within paperlist environment
% Usage: \chapter{<author>}{<chaptertitle>}{<editor(optional)>}{<booktitle>}{<edition(optional)>}{<location(optional)>}{<publisher>}{<year>}{<page>}{<URL(optional)>}{<other comments(optional)>}

\newcommand{\chapter}[3]{
    \item %
    #1. #2. In: \ifstrempty{#2}{}{#3. (eds.) }%
    \chapterContinued
}
\newcommand{\chapterContinued}[8]{
    \ifstrempty{#7}{\textit{#1}. }{\href{#7}{\textit{#1}}. }%
    \ifstrempty{#2}{}{#2 ed. }%
    \ifstrempty{#3}{}{#3: }%
    #4; #5. p. #6. %
    \ifstrempty{#8}{}{#8}%
}

% Presentation list environment
% Usage: \begin{prelist}\end{prelist}

\newenvironment{prelist}{
    \BeforeTextSkip
    \begin{itemize}[leftmargin=\ListTextIndent]
}{
    \AfterTextSkip
    \end{itemize}
}

% oral presentation entry, must be used within prelist environment
% Usage: \oral{<title>}{<conference>}{<location>}{<date>}{<URL(optional)>}{<other comments(optional)>}

\newcommand{\oral}[6]{
    \item[演\hspace{1em}讲] %
    \ifstrempty{#5}{#1. }{\href{#5}{#1}. }%
    \textit{#2}, #3 (#4). %
    \ifstrempty{#6}{}{#6}%
}

% poster presentation entry, must be used within prelist environment
% Usage: \poster{<title>}{<conference>}{<location>}{<date>}{<URL(optional)>}{<other comments(optional)>}

\newcommand{\poster}[6]{
    \item[海\hspace{1em}报] %
    \ifstrempty{#5}{#1. }{\href{#5}{#1}. }%
    \textit{#2}, #3 (#4). %
    \ifstrempty{#6}{}{#6}%
}

% keynote presentation entry, must be used within prelist environment
% Usage: \keynote{<title>}{<conference>}{<location>}{<date>}{<URL(optional)>}{<other comments(optional)>}

\newcommand{\keynote}[6]{
    \item[主\hspace{1em}旨] %
    \ifstrempty{#5}{#1. }{\href{#5}{#1}. }%
    \textit{#2}, #3 (#4). %
    \ifstrempty{#6}{}{#6}%
}

% guest presentation entry, must be used within prelist environment
% Usage: \guest{<title>}{<conference>}{<location>}{<date>}{<URL(optional)>}{<other comments(optional)>}

\newcommand{\guest}[6]{
    \item[受\hspace{1em}邀] %
    \ifstrempty{#5}{#1. }{\href{#5}{#1}. }%
    \textit{#2}, #3 (#4). %
    \ifstrempty{#6}{}{#6}%
}

% Text description environment - used for all other descriptions

\newenvironment{text}{\BeforeTextSkip}{\AfterTextSkip}
